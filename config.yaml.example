## AI Honeypot config (optional)
##
## Everything here has sane defaults, so this file is optional. To tune it, drop
## a copy named `config.yaml` at ./data/config.yaml (the ./data volume is mounted
## to /data), or set HONEYPOT_CONFIG to an explicit path.

geoip:
  # Geolocate source IPs of inbound SSH connections via ip-api.com and attach
  # the result to connect/disconnect events in the JSONL log. Disable if the
  # honeypot has no outbound internet, or you'd rather not look the IP up via a
  # third-party service.
  enabled: true
  # Per-lookup timeout (seconds).
  timeout: 2.5
  # Optional explicit endpoint. The default free tier of ip-api.com is
  # rate-limited to ~45 req/min — fine for a honeypot; results are cached in memory.
  endpoint: "http://ip-api.com/json/{ip}?fields=status,country,countryCode,region,regionName,city,lat,lon,isp,org,as,query"
